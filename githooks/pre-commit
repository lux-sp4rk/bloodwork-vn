#!/usr/bin/env bash
# pre-commit hook — lint staged .rpy / .rnh files
#
# Usage: symlink this to .git/hooks/pre-commit
#   ln -s ../../githooks/pre-commit .git/hooks/pre-commit

set -e

echo "🔍 Linting staged Ren'Py scripts..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(rpy|rnh)$' || true)

if [[ -z "$STAGED_FILES" ]]; then
  echo "  No narrative scripts staged — skipping."
  exit 0
fi

# Try renpy-lint if available; graceful fallback
LINT_CMD=""
if command -v renpy-lint &>/dev/null; then
  LINT_CMD="renpy-lint"
elif command -v renpy &>/dev/null; then
  LINT_CMD="renpy -lint"
fi

ERRORS=0
for f in $STAGED_FILES; do
  if [[ -f "$f" ]]; then
    echo "  linting: $f"
    if [[ -n "$LINT_CMD" ]]; then
      $LINT_CMD "$f" 2>&1 | grep -v "^I18N" || true
    else
      # Basic syntax check — look for common issues
      if grep -n "syntax error" "$f" &>/dev/null; then
        echo "  ✗ syntax issue in $f"
        ERRORS=$((ERRORS + 1))
      fi
    fi
  fi
done

if [[ $ERRORS -gt 0 ]]; then
  echo ""
  echo "✗ Lint errors found. Fix before committing."
  exit 1
fi

echo "  ✓ All staged scripts passed."
exit 0
